# Copy this file to .env and fill in your own values.

# Server
PORT=3000

# Admin dashboard login (change this!)
ADMIN_PASSWORD=change-me-please

# YouTube source for the video/podcast library.
# Provide ONE of the following. Channel ID is recommended.
# Find your channel ID at: https://www.youtube.com/account_advanced
YT_CHANNEL_ID=
# Or a specific playlist:
YT_PLAYLIST_ID=

# Stripe (donations). Leave blank to show a "giving not yet configured" notice.
# Use test keys (sk_test_...) while developing: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Where Stripe sends the donor after checkout (defaults to the site root):
SITE_URL=http://localhost:3000
